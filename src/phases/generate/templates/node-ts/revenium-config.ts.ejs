/**
 * Revenium Metering Configuration
 * Generated by Revvy
 *
 * Centralized helper that builds the `usageMetadata` Revenium consumes for
 * every AI call. The patterns below mirror the canonical getting-started
 * examples shipped by the Revenium platform:
 *
 *   - OpenAI / Perplexity / fal.ai → wrapped client (Initialize + GetClient,
 *     method-chain API, metadata as 2nd arg of .create())
 *   - Anthropic → auto-patches the standard SDK on import; metadata is passed
 *     INLINE as a `usageMetadata` field on .messages.create({...})
 *   - Google GenAI / Vertex AI → controller pattern; metadata as 3rd arg
 *
 * Required env vars (loaded from .env automatically):
 *   REVENIUM_METERING_API_KEY=rev_mk_...
 *   REVENIUM_METERING_BASE_URL=https://api.revenium.ai   (optional, default)
 */
<%_ const hasOpenAI = providers.includes('OpenAI') || providers.includes('Azure OpenAI') -%>
<%_ const hasAnthropic = providers.includes('Anthropic') -%>
<%_ const hasLiteLLM = providers.includes('LiteLLM') -%>
<%_ const hasPerplexity = providers.includes('Perplexity') -%>
<%_ const hasGoogle = providers.includes('Google GenAI') || providers.includes('Google GenAI (legacy)') -%>
<%_ const hasVertex = providers.includes('Vertex AI') -%>
<%_ const isApiKey = organization.source === 'api-key' -%>

import "dotenv/config";
<%_ if (hasOpenAI) { -%>
import { Initialize as InitializeOpenAI, GetClient as GetOpenAIClient } from "@revenium/middleware/openai";
<%_ } -%>
<%_ if (hasAnthropic) { -%>
import "@revenium/middleware/anthropic"; // auto-patches @anthropic-ai/sdk on import
<%_ } -%>
<%_ if (hasPerplexity) { -%>
import { Initialize as InitializePerplexity, GetClient as GetPerplexityClient } from "@revenium/middleware/perplexity";
<%_ } -%>
<%_ if (hasLiteLLM) { -%>
import { initialize as initializeLiteLLM } from "@revenium/middleware/litellm";
<%_ } -%>
<%_ if (hasGoogle) { -%>
import { GoogleGenAIController } from "@revenium/middleware/google/genai";
<%_ } -%>
<%_ if (hasVertex) { -%>
import { VertexAIController } from "@revenium/middleware/google/vertex";
<%_ } -%>
import type { UsageMetadata } from "@revenium/middleware";

// ---------------------------------------------------------------------------
// Initialize providers that need an explicit Initialize() call.
// (Anthropic auto-patches on import, so it isn't listed here.)
// ---------------------------------------------------------------------------
<%_ if (hasOpenAI) { -%>
InitializeOpenAI();
<%_ } -%>
<%_ if (hasPerplexity) { -%>
InitializePerplexity();
<%_ } -%>
<%_ if (hasLiteLLM) { -%>
initializeLiteLLM();
<%_ } -%>

<%_ if (hasOpenAI) { -%>
/**
 * Revenium-instrumented OpenAI client. Use the method-chain API exactly as
 * shown — metadata is passed as the SECOND ARGUMENT to `.create()`, NOT as
 * a field on the params object.
 */
export const openai = GetOpenAIClient();

<%_ } -%>
<%_ if (hasPerplexity) { -%>
/** Revenium-instrumented Perplexity client. Same method-chain pattern as OpenAI. */
export const perplexity = GetPerplexityClient();

<%_ } -%>
<%_ if (hasGoogle) { -%>
/** Revenium-instrumented Google GenAI controller. */
export const googleAI = new GoogleGenAIController();

<%_ } -%>
<%_ if (hasVertex) { -%>
/** Revenium-instrumented Vertex AI controller. */
export const vertexAI = new VertexAIController();

<%_ } -%>
/**
 * Build the per-request `usageMetadata` from your application's auth
 * context. Pass the result wherever the SDK accepts metadata (see provider
 * examples below).
 */
export function createUsageMetadata(context: {
<%_ if (isApiKey) { -%>
  /** API key identifying the consumer (becomes the Revenium subscriber). */
  apiKey: string;
<%_ } else if (/^"[^"]*"$/.test(organization.customerIdExpression || '')) { -%>
  /** Customer ID (fixed value <%- safeForBlockComment(organization.customerIdExpression) %> in this project — no auth context) — wires `organizationName`. */
  customerId: string;
<%_ } else if (organization.customerIdExpression) { -%>
  /** Customer ID from your auth context — wires `organizationName`. */
  customerId: string;
<%_ } else { -%>
  /** Customer ID (set at setup time via `--customer-id-expression`) — wires `organizationName`. */
  customerId: string;
<%_ } -%>
<%_ if (products.length > 0) { -%>
  /** Which product or feature is making the call. */
  product?: <%- products.map(p => `"${p.name}"`).join(' | ') %>;
<%_ } -%>
<%_ if (agents.length > 0) { -%>
  /** Which agent is executing. */
  agent?: <%- agents.map(a => `"${a.name}"`).join(' | ') %>;
<%_ } -%>
<%_ if (taskTypes.length > 0) { -%>
  /** Task classification. */
  taskType?: <%- taskTypes.map(t => `"${t.name}"`).join(' | ') %> | string;
<%_ } else { -%>
  /** Task classification (e.g. "chat", "embed"). */
  taskType?: string;
<%_ } -%>
  /** Trace/session ID for correlating multiple calls. */
  traceId?: string;
}): UsageMetadata {
  return {
<%_ if (isApiKey) { -%>
    subscriber: {
      id: context.apiKey,
      credential: { name: "api-key", value: context.apiKey },
    },
<%_ } else { -%>
    organizationName: context.customerId,
<%_ } -%>
<%_ if (products.length > 0) { -%>
    productName: context.product,
<%_ } -%>
<%_ if (agents.length > 0) { -%>
    agent: context.agent,
<%_ } -%>
    taskType: context.taskType,
    traceId: context.traceId,
  };
}

<%_ if (agents.length > 0) { -%>
/**
 * Pre-bound metadata factories — one per agent. Use when the calling code
 * already knows which agent is running.
 */
export const agentMetadata = {
<%_ for (const agent of agents) { -%>
  "<%- agent.name %>": (context: {
<%_ if (isApiKey) { -%>
    apiKey: string;
<%_ } else { -%>
    customerId: string;
<%_ } -%>
<%_ if (products.length > 0) { -%>
    product?: <%- products.map(p => `"${p.name}"`).join(' | ') %>;
<%_ } -%>
    taskType?: string;
    traceId?: string;
  }) =>
    createUsageMetadata({ ...context, agent: "<%- agent.name %>" }),
<%_ } -%>
} as const;

<%_ } -%>

// =============================================================================
// CALL PATTERNS — copy these into your code, replacing the example identifiers
// =============================================================================
<%_ if (hasOpenAI) { -%>
/*
 * --- OpenAI ---
 *
 *   const meta = createUsageMetadata({
<%_ if (isApiKey) { -%>
 *     apiKey: req.headers["x-api-key"] as string,
<%_ } else { -%>
 *     customerId: <%- safeForBlockComment(coerceCustomerId(organization.customerIdExpression || 'req.user.orgId')) %>,
<%_ } -%>
<%_ if (products.length > 0) { -%>
 *     product: "<%- products[0].name %>",
<%_ } -%>
<%_ if (agents.length > 0) { -%>
 *     agent: "<%- agents[0].name %>",
<%_ } -%>
 *   });
 *
 *   const response = await openai.chat().completions().create(
 *     {
 *       model: "gpt-4o-mini",
 *       messages: [{ role: "user", content: "Hello!" }],
 *     },
 *     meta,
 *   );
 *
 * Embeddings:
 *   const embedding = await openai.embeddings().create(
 *     { model: "text-embedding-3-small", input: ["hello"] },
 *     meta,
 *   );
 */
<%_ } -%>
<%_ if (hasAnthropic) { -%>
/*
 * --- Anthropic ---
 *
