 *   const anthropic = new Anthropic();
 *
 *   const response = await anthropic.messages.create({
 *     model: "claude-3-5-sonnet-20241022",
 *     max_tokens: 1024,
 *     messages: [{ role: "user", content: "Hello!" }],
 *     usageMetadata: createUsageMetadata({
<%_ if (isApiKey) { -%>
 *       apiKey: req.headers["x-api-key"] as string,
<%_ } else { -%>
 *       customerId: <%- safeForBlockComment(organization.customerIdExpression || 'req.user.orgId') %>,
<%_ } -%>
<%_ if (products.length > 0) { -%>
 *       product: "<%- products[0].name %>",
<%_ } -%>
<%_ if (agents.length > 0) { -%>
 *       agent: "<%- agents[0].name %>",
<%_ } -%>
 *     }),
 *   });
 */
<%_ } -%>
<%_ if (hasPerplexity) { -%>
/*
 * --- Perplexity --- (same shape as OpenAI)
 *
 *   const response = await perplexity.chat().completions().create(
 *     { model: "sonar-pro", messages: [{ role: "user", content: "..." }] },
 *     createUsageMetadata({ ... }),
 *   );
 */
<%_ } -%>
<%_ if (hasGoogle) { -%>
/*
 * --- Google GenAI ---
 *
 *   const response = await googleAI.createChat(
 *     ["What's the weather like?"],
 *     "gemini-2.0-flash-001",
 *     {
 *       organizationName: <%- safeForBlockComment(coerceCustomerId(organization.customerIdExpression || 'req.user.orgId')) %>,
<%_ if (products.length > 0) { -%>
 *       productName: "<%- products[0].name %>",
<%_ } -%>
<%_ if (agents.length > 0) { -%>
 *       agent: "<%- agents[0].name %>",
<%_ } -%>
 *     },
 *   );
 */
<%_ } -%>
<%_ if (hasVertex) { -%>
/*
 * --- Vertex AI --- (same shape as Google GenAI)
 *
 *   const response = await vertexAI.createChat(["..."], "gemini-2.0-flash-001", { ... });
 */
<%_ } -%>
<%_ if (hasLiteLLM) { -%>
/*
 * --- LiteLLM ---
 *
 * The middleware patches global fetch. Send Revenium fields as headers on the
 * proxy call (see https://docs.revenium.io for x-revenium-* header names).
 */
<%_ } -%>
