def create_usage_metadata(
<%_ if (isApiKey) { -%>
    api_key: str,
<%_ } else { -%>
    customer_id: str,
<%_ } -%>
<%_ if (products.length > 0) { -%>
    product: Optional[str] = None,
<%_ } -%>
<%_ if (agents.length > 0) { -%>
    agent: Optional[str] = None,
<%_ } -%>
    task_type: Optional[str] = None,
    trace_id: Optional[str] = None,
    agentic_job_id: Optional[str] = None,
    agentic_job_name: Optional[str] = None,
) -> Dict[str, Any]:
    """
    Build the per-request `usage_metadata` dict from your application's
    auth context. Pass the result as the `usage_metadata` keyword
    on any provider call.

    Args:
<%_ if (isApiKey) { -%>
        api_key: API key identifying the consumer (becomes the Revenium subscriber).
<%_ } else if (/^"[^"]*"$/.test(organization.customerIdExpression || '')) { -%>
        customer_id: Customer ID (fixed value <%- safeForBlockComment(organization.customerIdExpression) %> in this project — no auth context) — wires `organizationName`.
<%_ } else if (organization.customerIdExpression) { -%>
        customer_id: Customer ID from your auth context — wires `organizationName`.
<%_ } else { -%>
        customer_id: Customer ID (set at setup time via `--customer-id-expression`) — wires `organizationName`.
<%_ } -%>
<%_ if (products.length > 0) { -%>
        product: One of <%- products.map(p => `"${p.name}"`).join(', ') %>.
<%_ } -%>
<%_ if (agents.length > 0) { -%>
        agent: One of <%- agents.map(a => `"${a.name}"`).join(', ') %>.
<%_ } -%>
        task_type: Optional task classification.
        trace_id: Optional trace/session ID for correlation.
        agentic_job_id: Optional unique identifier tied to a business outcome (AI Outcomes).
        agentic_job_name: Optional human-readable job name for the agentic outcome.
    """
    metadata: Dict[str, Any] = {}

<%_ if (isApiKey) { -%>
    metadata["subscriber"] = {
        "id": api_key,
        "credential": {"name": "api-key", "value": api_key},
    }
<%_ } else { -%>
    metadata["organizationName"] = customer_id
<%_ } -%>
<%_ if (products.length > 0) { -%>
    if product:
        metadata["productName"] = product
<%_ } -%>
<%_ if (agents.length > 0) { -%>
    if agent:
        metadata["agent"] = agent
<%_ } -%>
    if task_type:
        metadata["task_type"] = task_type
    if trace_id:
        metadata["trace_id"] = trace_id
    if agentic_job_id:
        metadata["agentic_job_id"] = agentic_job_id
    if agentic_job_name:
        metadata["agentic_job_name"] = agentic_job_name

    return metadata


<%_ if (agents.length > 0) { -%>
# ----------------------------------------------------------------------------
# Per-agent decorator helpers — wrap a function so every AI call inside it
# carries the right agent attribution. Inject your auth accessor via
# `get_<%- isApiKey ? 'api_key' : 'customer_id' %>`.
# ----------------------------------------------------------------------------
<%_ for (const agent of agents) { -%>

def track_as_<%- agent.name.replace(/[^a-zA-Z0-9_]/g, '_') %>(
<%_ if (isApiKey) { -%>
    get_api_key: Optional[Callable[[], str]] = None,
<%_ } else { -%>
    get_customer_id: Optional[Callable[[], str]] = None,
<%_ } -%>
<%_ if (products.length > 0) { -%>
    product: Optional[str] = "<%- products[0].name %>",
<%_ } -%>
):
    """
    Decorator that injects Revenium metadata for the '<%- agent.name %>' agent.

    Example:
        @track_as_<%- agent.name.replace(/[^a-zA-Z0-9_]/g, '_') %>(get_<%- isApiKey ? 'api_key' : 'customer_id' %>=lambda: current_user().<%- isApiKey ? 'api_key' : 'org_id' %>)
        def handle_query(query):
            return client.chat.completions.create(...)
    """
    def decorator(func):
        @wraps(func)
        def wrapper(*args, **kwargs):
            metadata = create_usage_metadata(
<%_ if (isApiKey) { -%>
                api_key=get_api_key() if get_api_key else "unknown",
<%_ } else { -%>
                customer_id=get_customer_id() if get_customer_id else "unknown",
<%_ } -%>
<%_ if (products.length > 0) { -%>
                product=product,
<%_ } -%>
                agent="<%- agent.name %>",
            )
            kwargs.setdefault("usage_metadata", {}).update(metadata)
            return func(*args, **kwargs)
        return wrapper
    return decorator
<%_ } -%>
<%_ } -%>


