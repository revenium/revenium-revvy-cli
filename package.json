{
  "name": "@revenium/revvy",
  "version": "1.0.0",
  "description": "Revvy — AI-powered assistant for Revenium",
  "type": "module",
  "bin": {
    "revvy": "./bin/revvy.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "bin/",
    "dist/",
    "!dist/**/*.map",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "smoke": "esbuild scripts/test-scenarios.ts --bundle --platform=node --target=node18 --format=esm --outfile=dist/smoke.mjs --loader:.ejs=text --banner:js=\"import { createRequire } from 'module'; const require = createRequire(import.meta.url);\" && node dist/smoke.mjs",
    "build:docs": "tsx scripts/build-agent-guide.ts",
    "prepublishOnly": "pnpm build",
    "prepare": "husky"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/revenium/revenium-revvy-cli.git"
  },
  "homepage": "https://github.com/revenium/revenium-revvy-cli#readme",
  "bugs": {
    "url": "https://github.com/revenium/revenium-revvy-cli/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "revenium",
    "revvy",
    "cli",
    "ai",
    "llm",
    "metering",
    "instrumentation",
    "auto-instrumentation",
    "observability",
    "openai",
    "anthropic",
    "google",
    "ast",
    "typescript"
  ],
  "author": "Revenium <engineering@revenium.io>",
  "license": "MIT",
  "dependencies": {
    "@babel/parser": "^7.29.2",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "chalk": "^5.4.1",
    "diff": "^9.0.0",
    "ejs": "^3.1.10",
    "ignore": "^5.3.2",
    "ink": "^5.1.0",
    "ink-select-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/babel__traverse": "^7.28.0",
    "@types/ejs": "^3.1.5",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.12",
    "@types/yargs": "^17.0.33",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "tsup": "^8.3.5",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.58.2"
  }
}
